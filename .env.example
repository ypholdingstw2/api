cd C:\Shares\Coding\EqWizard_03\backend

@'
# Django 設定
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,www.yp.com.tw

# 資料庫設定（生產環境）
DB_NAME=eqwizard_db
DB_USER=eqwizard_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# CORS 設定（生產環境）
